# ─── Version Control ───────────────────────────────────────────
.git
.gitignore
.github

# ─── Python artifacts ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ─── Environment / Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
!frontend/.env.example

# ─── Databases (never copy into image) ─────────────────────────
*.sqlite3
*.db
test_*.db
diag.db
v.db
ci_test_db.sqlite3

# ─── Node / Frontend ───────────────────────────────────────────
frontend/node_modules/
# dist IS needed (built in Stage 1 inside Docker)
# frontend/dist/   <-- intentionally NOT ignored

# ─── ML models (mount as volume in production) ─────────────────
models/
data/

# ─── Logs & Media ──────────────────────────────────────────────
*.log
logs/
backend/logs/
staticfiles/
backend/staticfiles/
media/
backend/media/

# ─── IDE / OS ──────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# ─── Docs / CI notes ───────────────────────────────────────────
*.md
!README.md
docs/

# ─── Test / temp files ─────────────────────────────────────────
check_*.js
audit.py
test_realtime.py
verify_features.*
scripts/production_service_verification.py
scripts/quick_services_check.py
CI_CD_SETUP.md
