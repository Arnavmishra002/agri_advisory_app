# KrishiMitra AI — Render Build Configuration v2
#
# buildCommand: runs from repo root
# startCommand: gunicorn uses gunicorn.conf.py which sets chdir=backend/
#               so 'core' is importable without 'cd backend'

buildCommand: pip install -r requirements-production.txt && cd backend && python manage.py collectstatic --noinput
startCommand: gunicorn core.wsgi:application --config gunicorn.conf.py
