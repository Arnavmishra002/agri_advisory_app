# KrishiMitra AI — Render Build Configuration
# Render uses this to detect build/start commands automatically.

buildCommand: pip install -r backend/requirements.txt && cd backend && python manage.py collectstatic --noinput
startCommand: cd backend && gunicorn --bind 0.0.0.0:$PORT --workers 4 --threads 4 --worker-class gthread --timeout 120 core.wsgi:application
