# ═══════════════════════════════════════════════════════════════
# KrishiMitra AI — Environment Configuration
# Copy to .env at project root and fill in your values.
# NEVER commit .env to version control.
#
# Generate SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ═══════════════════════════════════════════════════════════════

# ── Django Core (REQUIRED in production) ────────────────────────
SECRET_KEY=
DEBUG=False
RATE_LIMIT_ENABLED=true
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_SETTINGS_MODULE=core.settings

# HTTPS behind reverse proxy (Render / Railway / Nginx)
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Database ─────────────────────────────────────────────────────
# SQLite — local dev only
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL — recommended for production
# DATABASE_URL=postgresql://user:password@host:5432/krishimitra

# ── data.gov.in — REQUIRED for live mandi prices ────────────────
# Free registration: https://data.gov.in/user/register → API Keys
# Without a registered key the app uses the public demo key
# (10 rows/request, rate-limited).
# The market prices endpoint will show status=unavailable until set.
DATA_GOV_IN_API_KEY=

# ── Google Gemini AI — optional (chat grounding) ────────────────
# https://aistudio.google.com/app/apikey (free tier available)
# Without this key the chatbot uses the built-in rule-based fallback
# which covers 22 languages and 60+ farming topics.
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash

# ── OpenWeatherMap — optional (Open-Meteo is free, no key needed) 
# https://openweathermap.org/api (free tier: 1000 calls/day)
# Open-Meteo is used by default — set this only for additional coverage.
OPENWEATHER_API_KEY=

# ── Redis / Celery — optional background tasks ──────────────────
REDIS_URL=redis://localhost:6379/0

# ── Sentry Error Monitoring — optional ──────────────────────────
SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────────
# Set SERVE_FRONTEND=true to have Django serve frontend/dist/ directly
# (useful for single-container deployments on Render/Railway)
SERVE_FRONTEND=false
FRONTEND_AT_ROOT=false
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-cdn.example

# ── Upload Limits ────────────────────────────────────────────────
# Maximum image upload size for KrishiRaksha (crop disease detection)
KRISHI_RAKSHA_MAX_UPLOAD_MB=5

# ── Feature Flags ────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false     # set true in production

# ── Local Dev Only ───────────────────────────────────────────────
# DEBUG=True
# RATE_LIMIT_ENABLED=false
# DATABASE_URL=sqlite:///db.sqlite3
# SECURE_SSL_REDIRECT=False

# ── WhatsApp Business API (Meta Cloud API) ────────────────────────
# HOW TO GET (free, 5 min setup):
#   1. Go to https://developers.facebook.com → Create App → WhatsApp Business
#   2. Add WhatsApp Business product to your app
#   3. Set Webhook URL: https://your-domain.com/api/sms-ivr/whatsapp/
#   4. Set Webhook Verify Token = same as WHATSAPP_VERIFY_TOKEN below
#   5. Copy the "Temporary Access Token" → WHATSAPP_TOKEN
#   6. Copy the "Phone Number ID"        → WHATSAPP_PHONE_ID
# FREE LIMITS: 1,000 conversations/month — no credit card for sandbox
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=krishimitra-webhook-secret-2025
WHATSAPP_APP_SECRET=

# ── Twilio SMS/IVR (Alternative channel) ─────────────────────────
# HOW TO GET: https://www.twilio.com/try-twilio (free $15 trial credit)
# Webhook URL: https://your-domain.com/api/sms-ivr/sms/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Groq Whisper STT — Voice messages for WhatsApp ───────────────
# Farmers send voice notes in Hindi/Bhojpuri/Tamil etc. — Groq transcribes.
# FREE: 7,200 audio seconds/day — no credit card needed
# HOW TO GET: https://console.groq.com → Sign up (GitHub login) → API Keys → Create Key
# Supported: Hindi, Marathi, Gujarati, Tamil, Telugu, Kannada, Bengali, Punjabi, English
GROQ_API_KEY=

# ── MQTT / IoT (ESP32 Sensor Integration) ────────────────────────
# Required only if you connect ESP32 soil sensors to the backend.
# For dev: leave as localhost (no broker needed unless ESP32 is connected).
# For prod: use a managed MQTT broker (HiveMQ Cloud free tier, or self-hosted Mosquitto).
# HOW TO SET UP: pip install paho-mqtt==1.6.1
#                Then run: python manage.py run_mqtt_subscriber
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=krishimitra/farm
MQTT_CLIENT_ID=krishimitra-backend

# ──────────────────────────────────────────────────────────────────
# SERVICES AND WHAT THEY NEED:
#
# ✅ Weather (Open-Meteo)        — No key needed, always real-time
# ✅ Soil layers (Open-Meteo)    — No key needed, field-level precision
# ✅ Crop recommendations         — No key needed, 80 crops, 126 districts
# ✅ Field advisory (IoT)         — No key needed, ICAR + Open-Meteo
# ✅ Government schemes           — No key needed, curated catalog
# ✅ Disease detection (ML)       — No key needed (model file optional)
# ✅ Session memory + admin panel — No key needed
# ⚠️  Mandi prices (live)         — Needs DATA_GOV_IN_API_KEY
# ⚠️  Chatbot (AI enhanced)       — Needs GOOGLE_AI_API_KEY (fallback works)
# ⚠️  WhatsApp replies            — Needs WHATSAPP_TOKEN + WHATSAPP_PHONE_ID
# ⚠️  Voice STT (WhatsApp audio)  — Needs GROQ_API_KEY (free 7200 sec/day)
# ⚠️  Twilio SMS replies          — Needs TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN
# ⚠️  ESP32 IoT sensors           — Needs MQTT_BROKER_HOST (local or cloud)
# ──────────────────────────────────────────────────────────────────
